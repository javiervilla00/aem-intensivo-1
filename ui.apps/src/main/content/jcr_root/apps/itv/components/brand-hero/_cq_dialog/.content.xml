<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
  xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0"
  xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
  jcr:primaryType="nt:unstructured"
  jcr:title="Configuración Hero de Marca"
  sling:resourceType="cq/gui/components/authoring/dialog">
  <content jcr:primaryType="nt:unstructured"
    sling:resourceType="granite/ui/components/coral/foundation/container">
    <items jcr:primaryType="nt:unstructured">
      <tabs jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/tabs"
        maximized="{Boolean}true">
        <items jcr:primaryType="nt:unstructured">
          <properties jcr:primaryType="nt:unstructured"
            jcr:title="Propiedades"
            sling:resourceType="granite/ui/components/coral/foundation/container"
            margin="{Boolean}true">
            <items jcr:primaryType="nt:unstructured">
              <bgImage jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                fieldLabel="Imagen de fondo"
                name="./bgImage"
                rootPath="/content/dam/itv/brands" />
              <invertImage jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                fieldLabel="Invertir imagen en eje x"
                text="Invertir imagen en eje x"
                name="./invertImage"
                value="{Boolean}true"
                uncheckedValue="{Boolean}false" />
              <bgPosition jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                fieldLabel="Punto Focal de la Imagen"
                fieldDescription="¿Qué parte de la imagen no debe recortarse nunca?"
                name="./bgPosition"
                emptyText="Por defecto (Centro)">
                <items jcr:primaryType="nt:unstructured">
                  <center jcr:primaryType="nt:unstructured" text="Centro (Recomendado)" value="center" />
                  <top jcr:primaryType="nt:unstructured" text="Arriba" value="top" />
                  <bottom jcr:primaryType="nt:unstructured" text="Abajo" value="bottom" />
                  <left jcr:primaryType="nt:unstructured" text="Izquierda" value="left" />
                  <right jcr:primaryType="nt:unstructured" text="Derecha" value="right" />
                </items>
              </bgPosition>
              <bgVideoMobile jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                fieldLabel="Video de fondo (móvil)"
                name="./bgVideoMobile"
                rootPath="/content/dam/itv/brands" />
              <bgVideoDesktop jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                fieldLabel="Video de fondo (escritorio)"
                name="./bgVideoDesktop"
                rootPath="/content/dam/itv/brands" />
              <logo jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                fieldLabel="Logo de la marca"
                name="./logo"
                rootPath="/content/dam/itv/logos" />
              <title jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                fieldLabel="Título de la marca" name="./title" />
              <subtitle jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                fieldLabel="Subtítulo" name="./subtitle" />
              <link jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                fieldLabel="Enlace botón modelos" name="./link"
                rootPath="/content/itv/us/en/landing-page-test" />
              <buttonText jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                fieldLabel="Texto botón ver modelos" name="./buttonText" />
              <textRight jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                fieldLabel="Texto a la derecha"
                text="Texto a la derecha"
                name="./textRight"
                value="{Boolean}true"
                uncheckedValue="{Boolean}false" />
            </items>
          </properties>
        </items>
      </tabs>
    </items>
  </content>
</jcr:root>